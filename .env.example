# ============================================================
# PLANIT — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS commiter le fichier .env.
# ============================================================

# ── Base de données ──────────────────────────────────────────
DATABASE_URL=postgresql://planit:planit_dev_password@localhost:5432/planit_dev

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO (stockage fichiers) ─────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=planit_minio
MINIO_SECRET_KEY=planit_minio_dev
MINIO_BUCKET=planit-dev

# ── Backend ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Auth (Vague 02) ───────────────────────────────────────────
JWT_SECRET=change_me_before_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_before_production
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Email (Vague 02) ──────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@ism.edu.sn

# ── WhatsApp / Orange SMS (Vague 04) ─────────────────────────
WHATSAPP_SESSION_PATH=./whatsapp-session
ORANGE_SMS_API_KEY=xxxxxxxxxxxxxxxxxxxx
ORANGE_SMS_SENDER=PLANIT

# ── Fuseau horaire ────────────────────────────────────────────
TZ=Africa/Dakar
