# ============================================================
#  PLANIT Backend — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs.
#  .env est gitignored — ne jamais committer les vraies valeurs.
# ============================================================

# ── Base de données PostgreSQL ───────────────────────────────
# Valeurs de dev : voir infra/docker-compose.dev.yml
# Lancer le conteneur : docker compose -f infra/docker-compose.dev.yml up -d
DATABASE_URL=postgresql://planit:planit_dev_password@localhost:5432/planit_dev

# ── Base de données de test ──────────────────────────────────
# Les tests d'intégration (pnpm test) utilisent une base dédiée `planit_test`.
# Elle est créée automatiquement au premier démarrage du conteneur Postgres
# (script infra/postgres/initdb/). Si le volume Postgres existe déjà :
#   docker compose -f infra/docker-compose.dev.yml exec postgres \
#     psql -U planit -c 'CREATE DATABASE planit_test;'
# Aucune variable à définir : vitest.config.ts cible `planit_test` par défaut.

# ── Serveur ──────────────────────────────────────────────────
# Port d'écoute du backend NestJS (défaut : 3001)
PORT=3001

# ── CORS ─────────────────────────────────────────────────────
# URL du frontend autorisé (défaut : http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# ── Redis (Vague 02 — BullMQ + sessions) ─────────────────────
# Valeurs de dev : voir infra/docker-compose.dev.yml
# REDIS_URL=redis://localhost:6379

# ── Auth JWT (Vague 02 — LOT 1) ───────────────────────────────
# Deux secrets séparés (cf. ADR-0005 §1 + ADR-0007). Min 32 caractères.
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=ac4d56115e7d6f3dc26adcf2deaf53c694300099694f95bbe0738f5d8671e910
JWT_REFRESH_SECRET=41df215567fd7a59ce2e2b91a44dbc5dbd9a79bef5eb398cbb92df373de7089c
# TTL en secondes — access 15 min, refresh 7 jours (cf. ADR-0005 §4).
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── MinIO / Stockage fichiers (Vague 03) ─────────────────────
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=planit
