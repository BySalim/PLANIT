# ============================================================
#  PLANIT Backend — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs.
#  .env est gitignored — ne jamais committer les vraies valeurs.
# ============================================================

# ── Base de données PostgreSQL ───────────────────────────────
# Valeurs de dev : voir infra/docker-compose.dev.yml
# Lancer le conteneur : docker compose -f infra/docker-compose.dev.yml up -d
DATABASE_URL=postgresql://planit:planit_dev_password@localhost:5432/planit_dev

# ── Serveur ──────────────────────────────────────────────────
# Port d'écoute du backend NestJS (défaut : 3001)
PORT=3001

# ── CORS ─────────────────────────────────────────────────────
# URL du frontend autorisé (défaut : http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# ── Redis (Vague 02 — BullMQ + sessions) ─────────────────────
# Valeurs de dev : voir infra/docker-compose.dev.yml
# REDIS_URL=redis://localhost:6379

# ── Auth JWT (Vague 02) ───────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# JWT_SECRET=change_me_in_production
# JWT_EXPIRES_IN=7d

# ── MinIO / Stockage fichiers (Vague 03) ─────────────────────
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=planit
