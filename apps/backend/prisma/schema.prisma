generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DIRECTION // V05 — pilotage scopé à une école (ADR-0020)
  RESPONSABLE_PROGRAMME
  ASSISTANT_PROGRAMME
  ENSEIGNANT
  ETUDIANT
  RESPONSABLE_CLASSE
  PARTENAIRE
}

// V05 — cycle de vie d'un compte (V5-D7 / ADR-0020). Suspendu = login refusé +
// sessions invalidées. L'archivage passe par `User.deletedAt` (soft-delete).
enum UserStatut {
  EN_ATTENTE
  ACTIF
  SUSPENDU
}

// V05 — état d'une école (ADR-0019). Archivée = sort des listes, jamais supprimée.
enum EcoleStatut {
  ACTIVE
  ARCHIVEE
}

// V01 enum — kept for backward compatibility with the V01 SeanceService/mapper.
// V02 introduces SessionTypeV2 + SessionSousType ; the service migration to
// the V02 enums is scheduled in LOT 2 V02 (Oumar), at which point this enum
// can be dropped along with `Seance.type` (legacy). Until then, both columns
// coexist on `Seance`.
enum SessionType {
  CM
  TD
  TP
  EXAM
  RATTRAP
  DEVOIR
  EVENT
}

enum SessionStatus {
  PROVISOIRE
  VALIDE
  PUBLIE
}

// V02 model — 3 categories. Migration LOT 2 (Oumar) will switch the API to
// rely on `Seance.typeV2` + `Seance.sousType`, then drop the V01 fields.
enum SessionTypeV2 {
  COURS
  EVALUATION
  EVENEMENT
}

// Optional sub-classification under COURS or EVALUATION. Null for EVENEMENT
// (or when the V02 fields are not yet populated for a legacy row).
enum SessionSousType {
  CM
  TD
  TP
  EXAMEN
  RATTRAPAGE
  DEVOIR
}

enum EnseignantStatut {
  PERMANENT
  VACATAIRE
}

enum FiliereGrade {
  LICENCE
  MASTER
  DOCTORAT
}

// V03 — niveau d'un plan d'études (porté par Maquette + Formation ; Classe
// en hérite via sa Formation). Doctorat hors scope V03 (V3-D12 / ADR-0010).
enum Niveau {
  L1
  L2
  L3
  M1
  M2
}

// V03 — état d'une année académique (V3-D1 / ADR-0010). Au plus une année
// `EN_COURS` à la fois, garanti par un index unique partiel Postgres ajouté
// en SQL brut dans la migration (Prisma ne sait pas l'exprimer).
enum AnneeEtat {
  PLANIFIEE
  EN_COURS
  CLOTUREE
  SUSPENDUE
}

// ─────────────────────────────────────────────────────────────────────────────
// Multi-tenance — Vague 05 (ADR-0019 / ADR-0020)
// ─────────────────────────────────────────────────────────────────────────────
// `Ecole` = tenant racine. `ecoleId` ajouté sur les racines de scope (User,
// Filiere, Salle, Enseignant, AnneeAcademique) ; les chaînes héritent par FK.
// Migration additive + backfill « École d'Ingénieurs » (cf. migration scriptée).
// ─────────────────────────────────────────────────────────────────────────────

model Ecole {
  id         String      @id @default(cuid())
  nom        String      @unique
  statut     EcoleStatut @default(ACTIVE)
  archivedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  users            User[]
  filieres         Filiere[]
  salles           Salle[]
  enseignants      Enseignant[]
  anneesAcademiques AnneeAcademique[]
  // V05 LOT 6 — UE rattachées à l'école (ADR-0022).
  ues              UE[]

  @@map("ecoles")
}

// Journal d'audit des actions sensibles (V5-D8 / ADR-0020). Écrit dans la même
// transaction que l'action quand c'est possible, via un AuditService mutualisé.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String // ex. « user.suspend », « ecole.archive », « annee.debuter »
  targetType String
  targetId   String?
  ecoleId    String? // scope optionnel (null = action cross-école)
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([ecoleId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  fullName       String
  role           Role
  // V05 — null pour ADMIN/SUPER_ADMIN (cross-école), requis sinon (ADR-0019).
  ecoleId        String?
  ecole          Ecole?     @relation(fields: [ecoleId], references: [id])
  statut         UserStatut @default(ACTIF) // V05 — cycle de vie compte (ADR-0020)
  passwordHash   String?
  refreshTokenId String? // V01 placeholder, deprecated by `refreshTokens` (LOT 2 cleanup)
  matricule      String?   @unique
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // V01/V02 — FK directe étudiant→classe. V03 : la source de vérité devient
  // `Inscription` (cf. ADR-0011) ; `classeId` conservé en transition, drop
  // tracé `TD-V03-CLASSEID`.
  classeId String?
  classe   Classe? @relation(fields: [classeId], references: [id])

  // V01 — teacher relation on Seance; kept until LOT 2 migrates to Enseignant.
  taughtSeances Seance[] @relation("SeanceTeacher")

  enseignant    Enseignant?
  refreshTokens RefreshToken[]

  // ── V03 — rattachement AC (Attaché de Classe) ↔ RP (manager) ──────────
  // V3-D9 / ADR-0010 : un AC (ASSISTANT_PROGRAMME) est rattaché à UN RP.
  // Self-relation : `manager` = le RP de cet AC ; `assistants` = les AC d'un RP.
  managerRpId String?
  manager     User?   @relation("AcManager", fields: [managerRpId], references: [id], onDelete: SetNull)
  assistants  User[]  @relation("AcManager")

  // V03 — inscriptions de l'étudiant (ADR-0011).
  inscriptions Inscription[]

  // V03 — classes assignées à un AC par son RP (V3-D9).
  assignedClasses AssistantClasse[]

  // V03 — salles dont ce RP est responsable (V3-D10).
  responsableSalles Salle[] @relation("SalleResponsable")

  // V05 — filières dont ce RP est le Responsable (V5-D5 / ADR-0020).
  responsableFilieres Filiere[] @relation("FiliereResponsable")

  // V05 LOT 6 — espace de travail RP : entités créées par ce RP (ownerRpId,
  // ADR-0022). Immuable (onDelete: SetNull). Distinct de « Responsable ».
  ownedFilieres  Filiere[]   @relation("FiliereOwner")
  ownedUes       UE[]        @relation("UeOwner")
  ownedModules   Module[]    @relation("ModuleOwner")
  ownedMaquettes Maquette[]  @relation("MaquetteOwner")
  ownedClasses   Classe[]    @relation("ClasseOwner")
  ownedSeances   Seance[]    @relation("SeanceOwner")
  ownedSalles    Salle[]     @relation("SalleOwner")

  // V05 — actions tracées au journal d'audit (ADR-0020).
  auditLogs AuditLog[] @relation("AuditActor")

  // V05 LOT 7.1 — groupes de vue planning (presets custom) sauvegardés par cet
  // utilisateur (privés au créateur). onDelete: Cascade (préférence UI).
  planningViewGroups PlanningViewGroup[]

  @@index([managerRpId])
  @@index([ecoleId])
  @@map("users")
}

// Cf. ADR-0005 §5 (rotation refresh + détection de réutilisation) et ADR-0007.
model RefreshToken {
  id         String    @id @default(cuid())
  hash       String    @unique
  userId     String
  familyId   String
  userAgent  String?
  ip         String?
  issuedAt   DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Domaine académique
// ─────────────────────────────────────────────────────────────────────────────

model Filiere {
  id              String       @id @default(cuid())
  // V05 LOT 6 — sigle unique PAR école (plus global) : 2 écoles peuvent avoir
  // « GLRS ». Cf. @@unique([ecoleId, sigle]) ci-dessous.
  sigle           String
  libelle         String
  isDoubleDiplome Boolean      @default(false)
  grade           FiliereGrade
  classes         Classe[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // V05 — école propriétaire (ADR-0019, requis après backfill).
  ecoleId String
  ecole   Ecole  @relation(fields: [ecoleId], references: [id])

  // V05 — RP responsable de la filière (« Responsable », V5-D5 / ADR-0020).
  // Nullable : filière sans RP attitré (affichage « — / Non assigné »).
  responsableRpId String?
  responsableRp   User?   @relation("FiliereResponsable", fields: [responsableRpId], references: [id], onDelete: SetNull)

  // V05 LOT 6 — RP créateur = clé du périmètre de travail (ADR-0022). Immuable,
  // distinct de responsableRpId. Nullable (data legacy backfillée au reseed).
  ownerRpId String?
  ownerRp   User?   @relation("FiliereOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  // V03 — plans d'études et formations de cette filière (ADR-0010 / V3-D4).
  maquettes  Maquette[]
  formations Formation[]

  @@unique([ecoleId, sigle])
  @@index([ecoleId])
  @@index([responsableRpId])
  @@index([ownerRpId])
  @@map("filieres")
}

model Classe {
  id        String   @id @default(cuid())
  // V05 LOT 6 — code unique PAR propriétaire (ADR-0022), plus global.
  code      String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optional in this migration so existing seed data can land before a Filiere
  // is associated. Will tighten to NOT NULL when LOT 2 enforces filière on
  // classe creation.
  filiereId String?
  filiere   Filiere? @relation(fields: [filiereId], references: [id])

  // ── V03 — refonte Classe (V3-D5 / ADR-0010) ───────────────────────────
  // La classe est rattachée à une Formation (qui porte filière + année +
  // niveau). `formationId` nullable EN TRANSITION (la `filiereId` directe
  // ci-dessus reste pour compat ; bascule vers Formation au seed v3).
  // `capaciteMax` default 0 pour que la migration atterrisse sans backfill —
  // le seed pose les vraies capacités. « Places » = nb inscrits / capaciteMax.
  formationId String?
  formation   Formation? @relation(fields: [formationId], references: [id], onDelete: SetNull)

  capaciteMax Int @default(0)

  students    User[]
  seances     Seance[] // V01 — direct FK on Seance.classeId
  seanceLinks SeanceClasse[] // V02 — N-N join, used by LOT 2 onwards

  // V05 LOT 6 — RP créateur = clé du périmètre de travail (ADR-0022).
  ownerRpId String?
  ownerRp   User?   @relation("ClasseOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  // V03
  inscriptions    Inscription[]
  assistants      AssistantClasse[]
  suiviModules    SuiviModule[]

  @@unique([ownerRpId, code])
  @@index([formationId])
  @@index([ownerRpId])
  @@map("classes")
}

model UE {
  id        String   @id @default(cuid())
  // V05 LOT 6 — code unique PAR propriétaire (ADR-0022), plus global.
  code      String
  libelle   String
  color     String
  modules   Module[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V05 LOT 6 — école + RP créateur (ADR-0022). Nullable (data legacy
  // backfillée au reseed) ; école dérivable mais stockée pour le scope.
  ecoleId String?
  ecole   Ecole?  @relation(fields: [ecoleId], references: [id])
  ownerRpId String?
  ownerRp   User?  @relation("UeOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  @@unique([ownerRpId, code])
  @@index([ecoleId])
  @@index([ownerRpId])
  @@map("ues")
}

model Module {
  id   String @id @default(cuid())
  // V05 LOT 6 — code unique PAR propriétaire (ADR-0022), plus global.
  code String

  // V01 column kept ; V02 introduces `libelle` + `color` + `ueId`. The
  // V01 mapper still reads `name`; LOT 2 migrates consumers to `libelle`
  // then drops `name`.
  name String

  // V02 fields. Default "" lets the migration land without backfilling
  // existing rows ; the seed populates them, and LOT 2 will tighten to
  // NOT NULL (no default) once the new CRUD is online.
  libelle String  @default("")
  color   String  @default("#64748B")
  ueId    String?
  ue      UE?     @relation(fields: [ueId], references: [id], onDelete: Restrict)

  seances   Seance[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V05 LOT 6 — RP créateur = clé du périmètre (ADR-0022). École dérivable via UE.
  ownerRpId String?
  ownerRp   User?   @relation("ModuleOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  // V03 — présence du module dans des versions de maquette + suivis (ADR-0010/0012).
  maquetteModules MaquetteModule[]
  suiviModules    SuiviModule[]

  @@unique([ownerRpId, code])
  @@index([ueId])
  @@index([ownerRpId])
  @@map("modules")
}

model Salle {
  id        String   @id @default(cuid())
  name      String
  type      String
  capacity  Int
  seances   Seance[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V05 — école propriétaire (ADR-0019, requis après backfill).
  ecoleId String
  ecole   Ecole  @relation(fields: [ecoleId], references: [id])

  // V03 — RP responsable de la salle (V3-D10 / ADR-0010). Nullable : permet
  // le filtrage « salles dont son RP est responsable » côté AC. null ⇒ salle
  // commune (V5-D6) accessible à tous DANS l'école.
  rpResponsableId String?
  rpResponsable   User?   @relation("SalleResponsable", fields: [rpResponsableId], references: [id], onDelete: SetNull)

  // V05 LOT 6 — salle « subjective » (ADR-0022 §5) : salle privée hypothétique
  // créée par un RP, visible de lui seul dans la liste. ownerRpId = créateur.
  isSubjective Boolean @default(false)
  ownerRpId    String?
  ownerRp      User?   @relation("SalleOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  // V05 — nom unique PAR école (plus global) : deux écoles peuvent avoir une « Salle 101 ».
  @@unique([ecoleId, name])
  @@index([rpResponsableId])
  @@index([ecoleId])
  @@index([ownerRpId])
  @@map("salles")
}

// Table dédiée enseignant (1-1 avec User). V02 model. The V01 service still
// uses `Seance.teacherId` (FK → User) ; LOT 2 will switch consumers to
// `Seance.enseignantId` (FK → Enseignant) then drop the legacy column.
model Enseignant {
  id                  String           @id @default(cuid())
  userId              String           @unique
  nomComplet          String
  emailInstitutionnel String           @unique
  whatsapp            String?
  statut              EnseignantStatut
  specialite          String

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taughtSeances Seance[] @relation("SeanceEnseignant")

  // V05 — école propriétaire (ADR-0019, requis après backfill).
  ecoleId String
  ecole   Ecole  @relation(fields: [ecoleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ecoleId])
  @@map("enseignants")
}

// Singleton — id = 'singleton'. Read by GET /api/settings (public),
// written by PUT /api/settings (RP only, LOT 2).
model Settings {
  id           String   @id @default("singleton")
  dayStartHour Int      @default(8)
  dayEndHour   Int      @default(20)
  updatedAt    DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Séances — schema hybride V01 + V02 (LOT 0 V02)
// ─────────────────────────────────────────────────────────────────────────────
// V02 adds: libelle, typeV2, sousType, intervenantNom, description,
// publishedSnapshot, hasUnpublishedChanges, enseignantId, SeanceClasse (N-N).
// V01 columns kept: type (enum), status, classeId (singular), teacherId.
// LOT 2 V02 (Oumar) will:
//   1. switch the SeanceService to consume the V02 fields,
//   2. backfill SeanceClasse from classeId,
//   3. backfill enseignantId from teacherId,
//   4. drop the V01 columns in a subsequent migration.
// ─────────────────────────────────────────────────────────────────────────────

model Seance {
  id              String        @id @default(cuid())
  type            SessionType // V01 — to be removed in LOT 2
  status          SessionStatus @default(PROVISOIRE) // V01 — to be removed in LOT 2
  startAt         DateTime
  endAt           DateTime
  isPublished     Boolean       @default(false)
  lastModifiedAt  DateTime      @default(now())
  lastPublishedAt DateTime?

  // ── V02 fields (defaults make the migration backwards-compatible) ──
  libelle        String           @default("")
  typeV2         SessionTypeV2?
  sousType       SessionSousType?
  intervenantNom String?
  description    String?

  // Smart dirty — cf. ADR-0008.
  // publishedSnapshot = stableStringify(extractComparable(seance)) at last publish.
  publishedSnapshot     Json?
  hasUnpublishedChanges Boolean @default(true)

  // V01 — FK directes, conservées pour compatibilité.
  // classeId/moduleId restent NOT NULL (toujours requis V01 ET V02).
  // salleId/teacherId deviennent nullable en V02 LOT 2 : un EVENEMENT V02
  // peut ne pas avoir de salle ni d'enseignant interne (intervenant externe).
  // Le V01 service continue de les exiger via Zod (createSessionSchema).
  classeId String
  classe   Classe @relation(fields: [classeId], references: [id])

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id])

  salleId String?
  salle   Salle?  @relation(fields: [salleId], references: [id], onDelete: SetNull)

  teacherId String?
  teacher   User?   @relation("SeanceTeacher", fields: [teacherId], references: [id])

  // V02 — Enseignant FK (optionnel, peuplé en LOT 2).
  enseignantId String?
  enseignant   Enseignant? @relation("SeanceEnseignant", fields: [enseignantId], references: [id], onDelete: SetNull)

  // V02 — N-N classes (peuplé en LOT 2, vide en LOT 0).
  seanceClasses SeanceClasse[]

  // V05 LOT 6 — RP créateur = clé du périmètre (ADR-0022). Pilote le masquage
  // planning des séances en salle tierce/commune (vue Salle).
  ownerRpId String?
  ownerRp   User?   @relation("SeanceOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classeId, startAt])
  @@index([teacherId, startAt])
  @@index([ownerRpId, startAt])
  // V01 — accélère le scan déclenché par POST /api/sessions/publish.
  @@index([isPublished, classeId])
  // V02 — accélère le calcul hasUnpublishedChanges.
  @@index([isPublished, hasUnpublishedChanges])
  @@map("seances")
}

// N-N Seance ↔ Classe (V2-D6). Populé en LOT 2 (Oumar) — vide à la sortie du LOT 0.
model SeanceClasse {
  seanceId String
  classeId String

  seance Seance @relation(fields: [seanceId], references: [id], onDelete: Cascade)
  classe Classe @relation(fields: [classeId], references: [id], onDelete: Cascade)

  @@id([seanceId, classeId])
  @@index([classeId])
  @@map("seance_classes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Vague 03 — Référentiel académique versionné (ADR-0010 / 0011 / 0012)
// ─────────────────────────────────────────────────────────────────────────────
// Migration **additive** : aucun DROP, aucune transformation data. Tout est
// nullable / defaulté pour rester compatible avec le seed V02 et le service
// V01/V02. La règle « une seule AnneeAcademique EN_COURS » est un index unique
// PARTIEL ajouté en SQL brut dans la migration (Prisma ne sait pas l'exprimer).
// ─────────────────────────────────────────────────────────────────────────────

// Année académique — source de vérité de « l'année courante » (V3-D1 / ADR-0010).
model AnneeAcademique {
  id      String    @id @default(cuid())
  libelle String // « 2025-2026 » — unique PAR école (V05), plus global
  debut   DateTime
  fin     DateTime
  etat    AnneeEtat @default(PLANIFIEE)

  // V05 — école propriétaire (ADR-0019 §2, requis après backfill).
  ecoleId String
  ecole   Ecole  @relation(fields: [ecoleId], references: [id])

  maquetteVersions MaquetteVersion[]
  formations       Formation[]
  inscriptions     Inscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V05 — l'invariant « au plus une EN_COURS » devient « par école » : index
  // unique partiel Postgres sur (ecoleId) WHERE etat='EN_COURS' (cf. migration,
  // Prisma ne sait pas l'exprimer). @@index simple ici pour les filtres.
  @@unique([ecoleId, libelle])
  @@index([etat])
  @@index([ecoleId])
  @@map("annee_academiques")
}

// Maquette — identité stable d'un plan d'études (V3-D2 / ADR-0010).
// Ses propres dates (createdAt/updatedAt) sont affichées dans le modal infos.
model Maquette {
  id        String @id @default(cuid())
  nom       String // « Maquette GLRS L3 »
  filiereId String
  filiere   Filiere @relation(fields: [filiereId], references: [id])
  niveau    Niveau

  versions MaquetteVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // V05 LOT 6 — RP créateur = filière.ownerRpId, stocké pour filtrage direct (ADR-0022).
  ownerRpId String?
  ownerRp   User?   @relation("MaquetteOwner", fields: [ownerRpId], references: [id], onDelete: SetNull)

  // ADR-0018 : une seule maquette par (filière, niveau). Le `nom` est dérivé
  // (« Maquette {niveau} {sigle} ») — il n'entre plus dans la clé d'unicité.
  @@unique([filiereId, niveau])
  @@index([filiereId])
  @@index([ownerRpId])
  @@map("maquettes")
}

// Version d'une maquette pour une année donnée (V3-D2 / ADR-0010).
// « Renouveler » = cloner profondément la dernière version vers l'année courante.
model MaquetteVersion {
  id                String          @id @default(cuid())
  maquetteId        String
  maquette          Maquette        @relation(fields: [maquetteId], references: [id], onDelete: Cascade)
  anneeAcademiqueId String
  anneeAcademique   AnneeAcademique @relation(fields: [anneeAcademiqueId], references: [id])

  modules    MaquetteModule[]
  formations Formation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([maquetteId, anneeAcademiqueId]) // 1 version / an / maquette
  @@index([anneeAcademiqueId])
  @@map("maquette_versions")
}

// Module × semestre × heures saisies dans une version (V3-D2/D3 / ADR-0010).
// VHE/VHT JAMAIS stockés — dérivés via @planit/utils (computeVHE/computeVHT).
model MaquetteModule {
  id                String          @id @default(cuid())
  maquetteVersionId String
  maquetteVersion   MaquetteVersion @relation(fields: [maquetteVersionId], references: [id], onDelete: Cascade)
  moduleId          String
  module            Module          @relation(fields: [moduleId], references: [id])

  semestre  Int // 1 | 2 (rang dans l'année ; libellé S5/S6 dérivé du niveau)
  heuresCM  Int @default(0)
  heuresTD  Int @default(0)
  heuresTP  Int @default(0)
  heuresTPE Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([maquetteVersionId, moduleId]) // un module apparaît 1× par version
  @@index([moduleId])
  @@map("maquette_modules")
}

// Formation — instance annuelle d'une filière regroupant des classes (V3-D4).
model Formation {
  id                String          @id @default(cuid())
  code              String          @unique // « GLRS-L3-2025 »
  niveau            Niveau
  filiereId         String
  filiere           Filiere         @relation(fields: [filiereId], references: [id])
  anneeAcademiqueId String
  anneeAcademique   AnneeAcademique @relation(fields: [anneeAcademiqueId], references: [id])
  maquetteVersionId String
  maquetteVersion   MaquetteVersion @relation(fields: [maquetteVersionId], references: [id])

  // ADR-0018 : `isDoubleDiplome` n'est PLUS porté par la formation — c'est une
  // propriété de la Filiere (dérivée à l'affichage et à l'inscription).

  classes Classe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ADR-0018 : un seul choix (filière, niveau) par année courante (règle 2.1).
  @@unique([filiereId, niveau, anneeAcademiqueId])
  @@index([anneeAcademiqueId])
  @@index([filiereId])
  @@index([maquetteVersionId])
  @@map("formations")
}

// Inscription — etudiant × classe × année (V3-D7 / ADR-0011).
// `isDoubleDiplome` DÉNORMALISÉ depuis la formation de la classe : la règle
// double-diplôme (≤ 2/an, 1 par catégorie) est garantie EN BASE par le 2ᵉ
// @@unique, pas seulement en code.
model Inscription {
  id                String          @id @default(cuid())
  etudiantId        String
  etudiant          User            @relation(fields: [etudiantId], references: [id], onDelete: Cascade)
  classeId          String
  classe            Classe          @relation(fields: [classeId], references: [id], onDelete: Cascade)
  anneeAcademiqueId String
  anneeAcademique   AnneeAcademique @relation(fields: [anneeAcademiqueId], references: [id])
  isDoubleDiplome   Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([etudiantId, classeId, anneeAcademiqueId]) // anti-doublon strict
  @@unique([etudiantId, anneeAcademiqueId, isDoubleDiplome]) // règle double-diplôme (cœur)
  @@index([classeId])
  @@index([etudiantId])
  @@index([anneeAcademiqueId])
  @@map("inscriptions")
}

// Suivi d'un module pour une classe (V3-D8 / ADR-0012).
// État persistant MINIMAL : seul `estTermine` est stocké. heuresPrevues (VHE),
// heuresFaites (dérivé des séances COURS), progression et enseignants sont
// CALCULÉS à la lecture (LOT 2 B.5).
model SuiviModule {
  id         String    @id @default(cuid())
  classeId   String
  classe     Classe    @relation(fields: [classeId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module    @relation(fields: [moduleId], references: [id])
  estTermine Boolean   @default(false)
  termineAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classeId, moduleId])
  @@index([classeId])
  @@index([moduleId])
  @@map("suivi_modules")
}

// AC ↔ Classe — classes assignées à un AC par son RP (V3-D9 / ADR-0010).
model AssistantClasse {
  acId     String
  ac       User   @relation(fields: [acId], references: [id], onDelete: Cascade)
  classeId String
  classe   Classe @relation(fields: [classeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([acId, classeId])
  @@index([classeId])
  @@map("assistant_classes")
}

// V05 LOT 7.1 — groupe de vue planning : sous-ensemble ordonné de références
// (classes/salles/enseignants) qui définit les colonnes d'une vue by-X.
// Privé à son créateur (`userId`). `refIds` = ids ordonnés des références.
model PlanningViewGroup {
  id     String           @id @default(cuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  view   PlanningViewKind
  name   String
  refIds String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, view])
  @@map("planning_view_groups")
}

// Dimension d'une vue by-X à laquelle s'applique un groupe de vue.
enum PlanningViewKind {
  CLASSE
  SALLE
  PROF
}
