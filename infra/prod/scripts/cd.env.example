# Copier en /opt/planit/cd.env SUR LA BOX (hors repo → de fait non commité).
# Surcharge les défauts de cd-pull.sh et backup.sh. V04 LOT 8 / ADR-0017.
#
#   PROD réelle (Hetzner, planit.sn)  → IMAGE_TAG=main
#   VM staging (serveur de test)      → IMAGE_TAG=staging
#
# ⚠️ Secrets : aucune valeur réelle ici (ce .example documente). `age1…`, `<token>`
#    et l'IP/bucket sont des placeholders.

# ── Tag d'image suivi par le CD pull-based (cd-pull.sh) ──────────────────────
IMAGE_TAG=main

# Domaine servi par Caddy (le smoke du CD le vise en HTTPS).
PLANIT_DOMAIN=planit.sn

# Emplacements (défauts /opt/planit/...) — décommenter si besoin de surcharger.
# PLANIT_APP_DIR=/opt/planit
# PLANIT_COMPOSE_DIR=/opt/planit/src/infra
# PLANIT_ENV_FILE=/opt/planit/.env.prod

# ── Sauvegardes (consommées par backup.sh) ───────────────────────────────────
# Clé PUBLIQUE age (chiffrement au repos). La clé privée reste HORS box.
PLANIT_BACKUP_AGE_RECIPIENT=age1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Off-box NFS (TrueNAS) monté localement (cible off-site n°1).
PLANIT_BACKUP_OFFBOX_DIR=/mnt/truenas/planit-backups
# Off-site CLOUD (cible off-site n°2, LOT 8.9) — remote rclone `remote:bucket/chemin`
# (Backblaze B2 ou Cloudflare R2, configuré via `rclone config` sur la box).
PLANIT_BACKUP_CLOUD_REMOTE=r2:planit-backups/prod
# Purge d'âge best-effort côté cloud (privilégier une lifecycle rule du bucket).
PLANIT_BACKUP_CLOUD_KEEP_DAYS=30
# Alerte échec / heartbeat de succès (Uptime Kuma push monitor).
PLANIT_BACKUP_PUSH_URL=http://127.0.0.1:3011/api/push/<token>

# ── Rétention GFS locale (défauts 7 / 4 / 6 si absents) ──────────────────────
# PLANIT_BACKUP_KEEP_DAILY=7
# PLANIT_BACKUP_KEEP_WEEKLY=4
# PLANIT_BACKUP_KEEP_MONTHLY=6
