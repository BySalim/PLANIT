# ============================================================
#  PLANIT — Variables d'environnement PROD (V04 LOT 1.5, ADR-0013 §8)
#  Copier en `infra/prod/env/.env.prod` et remplir. `.env.prod` est GITIGNORED.
#  Démarrer la stack :
#    docker compose --env-file infra/prod/env/.env.prod \
#      -f infra/docker-compose.prod.yml up -d --build
#  ⚠️ Secrets : `openssl rand -hex 32`. JAMAIS de valeur par défaut en ligne (V4-D16).
# ============================================================

# ── Tag d'image (CD : <sha> ; local : `local`) ───────────────
IMAGE_TAG=local

# ── PostgreSQL (runtime) ─────────────────────────────────────
POSTGRES_USER=planit
POSTGRES_PASSWORD=__CHANGER_MOT_DE_PASSE_FORT__
POSTGRES_DB=planit
# Host = nom du service compose (`postgres`), pas localhost.
DATABASE_URL=postgresql://planit:__CHANGER_MOT_DE_PASSE_FORT__@postgres:5432/planit

# ── Redis (runtime) ──────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO (runtime) ──────────────────────────────────────────
MINIO_ROOT_USER=planit_minio
MINIO_ROOT_PASSWORD=__CHANGER_MOT_DE_PASSE_FORT__

# ── Auth JWT (runtime) — 2 secrets séparés, ≥ 32 caractères ───
JWT_ACCESS_SECRET=__openssl_rand_hex_32__
JWT_REFRESH_SECRET=__openssl_rand_hex_32_DIFFERENT__
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── Réseau / reverse-proxy (runtime) ─────────────────────────
# Domaine servi par Caddy. `localhost` pour le smoke local / VM sans domaine.
PLANIT_DOMAIN=localhost
# TLS : `internal` (CA Caddy, local/VM) OU un email (Let's Encrypt, domaine réel).
CADDY_TLS=internal
# URL frontend autorisée par le CORS backend.
FRONTEND_URL=https://localhost
# Niveau de log pino backend.
LOG_LEVEL=info

# ── Build-time (web) — NEXT_PUBLIC_* inlinés dans le bundle client ────────────
# Passés en build args par le workflow CD. URL WebSocket publique (même origine
# en prod → wss://<domaine>). Laisser vide en local (WS non requis au smoke).
NEXT_PUBLIC_WS_URL=

# ── Beta publique — Cloudflare Tunnel (ADR-0015, profil compose `tunnel`) ──────
# Token du named tunnel (dashboard CF → Zero Trust → Tunnels). Requis UNIQUEMENT
# pour `docker compose --profile tunnel up -d cloudflared`. Laisser vide sinon.
# Secret → ne PAS commiter (.env.prod est gitignored ; ce .example documente).
# Sans domaine pour l'instant : préférer le quick-tunnel (cf. beta-tunnel.md).
CLOUDFLARE_TUNNEL_TOKEN=

# ── Observabilité (ADR-0009 Phase 2, profil compose `observability`) ──────────
# `docker compose --profile observability up -d` lance Dozzle (logs) + Uptime
# Kuma (uptime) + Prometheus + Grafana, bindés sur 127.0.0.1 (SSH local-forward).
# Grafana exige un mot de passe admin (UNIQUEMENT avec le profil observability) :
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__CHANGER_MOT_DE_PASSE_FORT__
# Les variables de SAUVEGARDE (chiffrement age, GFS, off-box, alerte push Uptime
# Kuma) se mettent dans /opt/planit/cd.env — cf. docs/runbooks/truenas-backup.md §6.

# ── Error tracking Sentry (ADR-0009 Phase 1) — DORMANT tant que vide ──────────
# Crée le projet Sentry (ou GlitchTip self-host), puis colle les DSN. Sans DSN :
# aucun report (no-op). Backend = SENTRY_DSN ; navigateur = NEXT_PUBLIC_SENTRY_DSN
# (build arg web). ⚠️ En prod avec DSN : ajouter l'hôte d'ingestion Sentry au
# `connect-src` de la CSP (apps/web/next.config.ts).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
