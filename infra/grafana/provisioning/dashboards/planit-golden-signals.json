{
  "uid": "planit-golden-signals",
  "title": "PLANIT — Golden Signals (backend)",
  "tags": ["planit", "backend", "RED"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Taux de requêtes (req/s)",
      "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "sum(rate(http_requests_total[5m]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Taux d'erreur 5xx (%)",
      "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "100 * sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latence p95 (s)",
      "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Taux de requêtes par route / status",
      "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "sum(rate(http_requests_total[5m])) by (route, status)",
          "legendFormat": "{{route}} [{{status}}]"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latence p95 par route (s)",
      "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Process backend — mémoire résidente & event-loop lag p99",
      "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "process_resident_memory_bytes{service=\"planit-backend\"}",
          "legendFormat": "RSS (bytes)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "planit-prometheus" },
          "expr": "nodejs_eventloop_lag_p99_seconds{service=\"planit-backend\"}",
          "legendFormat": "event-loop lag p99 (s)"
        }
      ]
    }
  ]
}
