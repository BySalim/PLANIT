{
  "name": "planit",
  "private": true,
  "version": "0.1.0",
  "author": "Salim Ouedraogo <salim-taoufiq.ouedraogo@ism.edu.sn>",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" --filter \"!@planit/mobile\" dev",
    "dev:mobile": "pnpm --filter @planit/mobile dev",
    "dev:all": "pnpm -r --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "db:migrate": "pnpm --filter @planit/backend db:migrate",
    "db:seed": "pnpm --filter @planit/backend db:seed",
    "db:reset": "pnpm --filter @planit/backend db:reset",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .gitignore",
    "prepare": "husky",
    "postinstall": "pnpm --filter @planit/contracts build && pnpm --filter @planit/utils build"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.49.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "turbo": "^2.9.16",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "vitest": "3.2.6",
      "@vitest/coverage-v8": "3.2.6"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "@swc/core",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "@scarf/scarf"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "pnpm exec prettier --write"
    ]
  }
}
