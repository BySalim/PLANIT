{
  "name": "@planit/contracts",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "default": "./dist/auth/index.js"
    },
    "./planning": {
      "types": "./src/planning/index.ts",
      "default": "./dist/planning/index.js"
    },
    "./notifications": {
      "types": "./src/notifications/index.ts",
      "default": "./dist/notifications/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@planit/config": "workspace:*",
    "typescript": "^5.8.3"
  }
}
